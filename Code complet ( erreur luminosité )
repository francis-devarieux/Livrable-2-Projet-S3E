#include <Arduino.h>
#include <Wire.h>
#include "SdFat.h"
#include <RTClib.h>
#include <rgb_lcd.h>
#include <ChainableLED.h>
#include <SoftwareSerial.h>
#include <TinyGPS++.h>
#include "DHT.h"
#include <avr/interrupt.h>
#include <math.h>

// --- CONFIGURATION ---
const int SD_CS = 4;
const int DHT_PIN = 5;
const int LIGHT_PIN = A2;
const unsigned int MAX_SZ = 4096;

enum Mode { STD, ECO, CONF, MAINT };
Mode mode = STD;

unsigned long bv = 0, br = 0, dl = 0, dd = 0;
bool bvl = false, brl = false;

SdFat sd;
File logF;
RTC_DS1307 rtc;
rgb_lcd lcd;
ChainableLED leds(6, 7, 1);
DHT dht(DHT_PIN, DHT11);
SoftwareSerial ss(A0, A1);
TinyGPSPlus gps;

// =======================
//  GESTION DES ERREURS
// =======================
enum ErrorCode {
  ERR_NONE = 0,
  ERR_RTC,
  ERR_GPS,
  ERR_SENSOR_ACCESS,
  ERR_SENSOR_INCOH,
  ERR_SD_FULL,
  ERR_SD_RW
};

volatile bool ledUpdateFlag = false;
volatile bool phaseIsSecondColor = false;
volatile uint16_t tickMs = 0;
volatile uint16_t durA = 500;

ErrorCode currentErr = ERR_NONE;
ErrorCode prevErr = ERR_NONE;

bool rtcOK = false;
bool sdOK = false;

unsigned long lastGpsByteMs = 0;
const unsigned long GPS_TIMEOUT_MS = 5000;

unsigned long fixedMsgUntil = 0;
bool needNormalRefresh = false;

unsigned long lastRtcCheck = 0;
unsigned long lastSdCheck = 0;
unsigned long lastLightCheck = 0;

const unsigned long RTC_CHECK_MS = 1000;
const unsigned long SD_CHECK_MS = 2000;
const unsigned long LIGHT_CHECK_MS = 1000;

uint8_t sdFailCount = 0;

float lastTemp = NAN;
float lastHum = NAN;
int lastLight = 0;

// --- COULEURS ---
const uint8_t RR = 255, RG = 0,   RB = 0;
const uint8_t BR = 0,   BG = 0,   BB = 255;
const uint8_t YR = 255, YG = 255, YB = 0;
const uint8_t GR = 0,   GG = 255, GB = 0;
const uint8_t WR = 255, WG = 255, WB = 255;

static inline bool fixedMsgActive() {
  return millis() < fixedMsgUntil;
}

// =======================
// INTERRUPTION TIMER 1 ms
// =======================
ISR(TIMER1_COMPA_vect) {
  tickMs++;
  if (tickMs >= 1000) tickMs = 0;

  bool newPhase = (tickMs >= durA);
  if (newPhase != phaseIsSecondColor) {
    phaseIsSecondColor = newPhase;
    ledUpdateFlag = true;
  }
}

void timer1_init_1ms() {
  cli();
  TCCR1A = 0;
  TCCR1B = 0;
  TCNT1 = 0;
  TCCR1B |= (1 << WGM12);
  OCR1A = 249;
  TCCR1B |= (1 << CS11) | (1 << CS10);
  TIMSK1 |= (1 << OCIE1A);
  sei();
}

// =======================
// OUTILS
// =======================
void ledSet(uint8_t r, uint8_t g, uint8_t b) {
  leds.setColorRGB(0, r, g, b);
}

void setBlinkPatternForError(ErrorCode e) {
  if (e == ERR_SENSOR_INCOH || e == ERR_SD_RW) durA = 333;
  else durA = 500;
}

bool i2cDevicePresent(uint8_t address) {
  Wire.beginTransmission(address);
  return (Wire.endTransmission() == 0);
}

bool rtcPresent() {
  return i2cDevicePresent(0x68);
}

bool sdHealthCheck() {
  return sd.begin(SD_CS);
}

// Heuristique pour la lumière : on essaie de détecter une entrée flottante
bool lightSensorPresentHeuristic(int &valueOut) {
  const int N = 8;
  int minV = 1023;
  int maxV = 0;
  long sum = 0;

  for (int i = 0; i < N; i++) {
    int v = analogRead(LIGHT_PIN);
    if (v < minV) minV = v;
    if (v > maxV) maxV = v;
    sum += v;
    delay(2);
  }

  valueOut = sum / N;

  // Entrée flottante souvent très instable : grosse dispersion
  // Heuristique, pas garantie à 100%
  if ((maxV - minV) > 120) return false;

  return true;
}

bool rtcTimeReadable(DateTime &dt) {
  if (!rtcPresent()) return false;
  dt = rtc.now();

  // Heuristique : si l'année est aberrante on considère la RTC non fiable
  if (dt.year() < 2020 || dt.year() > 2099) return false;

  return true;
}

void setLcdColorForError(ErrorCode e) {
  switch (e) {
    case ERR_RTC:           lcd.setRGB(0, 0, 255); break;
    case ERR_GPS:           lcd.setRGB(255, 255, 0); break;
    case ERR_SENSOR_ACCESS: lcd.setRGB(0, 255, 0); break;
    case ERR_SENSOR_INCOH:  lcd.setRGB(0, 255, 0); break;
    case ERR_SD_FULL:       lcd.setRGB(255, 255, 255); break;
    case ERR_SD_RW:         lcd.setRGB(255, 255, 255); break;
    default:
      if (mode == STD) lcd.setRGB(0,255,0);
      else if (mode == ECO) lcd.setRGB(0,0,255);
      else if (mode == CONF) lcd.setRGB(255,255,0);
      else lcd.setRGB(255,86,0);
      break;
  }
}

void applyErrorLedNow(ErrorCode e, bool secondColor) {
  switch (e) {
    case ERR_RTC:
      if (!secondColor) ledSet(RR,RG,RB); else ledSet(BR,BG,BB);
      break;
    case ERR_GPS:
      if (!secondColor) ledSet(RR,RG,RB); else ledSet(YR,YG,YB);
      break;
    case ERR_SENSOR_ACCESS:
    case ERR_SENSOR_INCOH:
      if (!secondColor) ledSet(RR,RG,RB); else ledSet(GR,GG,GB);
      break;
    case ERR_SD_FULL:
    case ERR_SD_RW:
      if (!secondColor) ledSet(RR,RG,RB); else ledSet(WR,WG,WB);
      break;
    default:
      break;
  }
}

void showErrorLCD(ErrorCode e) {
  lcd.clear();
  setLcdColorForError(e);
  lcd.setCursor(0, 0);
  lcd.print(F("ERREUR"));
  lcd.setCursor(0, 1);

  switch (e) {
    case ERR_RTC:           lcd.print(F("Acces RTC")); break;
    case ERR_GPS:           lcd.print(F("Acces GPS")); break;
    case ERR_SENSOR_ACCESS: lcd.print(F("Acces capteur")); break;
    case ERR_SENSOR_INCOH:  lcd.print(F("Capt incoher")); break;
    case ERR_SD_FULL:       lcd.print(F("SD pleine")); break;
    case ERR_SD_RW:         lcd.print(F("SD acces/ecr")); break;
    default: break;
  }
}

void showFixedLCD() {
  lcd.clear();
  if (mode == STD) lcd.setRGB(0,255,0);
  else if (mode == ECO) lcd.setRGB(0,0,255);
  else if (mode == CONF) lcd.setRGB(255,255,0);
  else lcd.setRGB(255,86,0);

  lcd.setCursor(0, 0);
  lcd.print(F("PROBLEME"));
  lcd.setCursor(0, 1);
  lcd.print(F("REGLE"));

  fixedMsgUntil = millis() + 2000UL;
  needNormalRefresh = true;
}

ErrorCode choosePriority(bool sdRw, bool sdFull, bool rtcFail, bool gpsFail, bool sensFail, bool sensIncoh) {
  if (sdRw) return ERR_SD_RW;
  if (sdFull) return ERR_SD_FULL;
  if (rtcFail) return ERR_RTC;
  if (gpsFail) return ERR_GPS;
  if (sensFail) return ERR_SENSOR_ACCESS;
  if (sensIncoh) return ERR_SENSOR_INCOH;
  return ERR_NONE;
}

void updateError(ErrorCode newErr) {
  currentErr = newErr;
  setBlinkPatternForError(newErr);
}

void restoreModeLed() {
  if (mode == STD) ledSet(0,255,0);
  else if (mode == ECO) ledSet(0,0,255);
  else if (mode == CONF) ledSet(255,255,0);
  else ledSet(255,86,0);
}

void setM(Mode m, uint8_t r, uint8_t g, uint8_t b) {
  mode = m;
  if (currentErr == ERR_NONE && !fixedMsgActive()) {
    ledSet(r, g, b);
    lcd.setRGB(r, g, b);
  }
  needNormalRefresh = true;
}

void drawNormalScreen(float t, float h, int lightValue, bool lightOK, bool rtcReadable) {
  lcd.clear();
  if (mode == STD) lcd.setRGB(0,255,0);
  else if (mode == ECO) lcd.setRGB(0,0,255);
  else if (mode == CONF) lcd.setRGB(255,255,0);
  else lcd.setRGB(255,86,0);

  lcd.print(F("M:"));

  if (mode == STD) {
    static int p = 0;
    lcd.print(F("STD"));
    lcd.setCursor(0,1);

    if (p == 0) {
      lcd.print((int)t);
      lcd.print(F("C "));
      lcd.print((int)h);
      lcd.print(F("%H"));
    }
    else if (p == 1) {
      if (gps.location.isValid()) {
        lcd.print(gps.location.lat(),1);
        lcd.print(F(" "));
        lcd.print(gps.location.lng(),1);
      } else {
        lcd.print(F("NO GPS"));
      }
    }
    else if (p == 2) {
      if (rtcReadable) {
        DateTime n = rtc.now();
        if (n.hour() < 10) lcd.print('0');
        lcd.print(n.hour());
        lcd.print(':');
        if (n.minute() < 10) lcd.print('0');
        lcd.print(n.minute());
      } else {
        lcd.print(F("NO RTC"));
      }
    }
    else {
      if (lightOK) {
        lcd.print(F("LUM:"));
        lcd.print(lightValue);
      } else {
        lcd.print(F("NO LIGHT"));
      }
    }

    p = (p + 1) % 4;
  } else {
    lcd.print(mode == ECO ? F("ECO") : mode == MAINT ? F("MAINT") : F("CONF"));
    lcd.setCursor(0,1);
    lcd.print(F("ACTIF"));
  }
}

// =======================
// SETUP
// =======================
void setup() {
  Wire.begin();
  ss.begin(9600);
  lcd.begin(16, 2);
  dht.begin();

  pinMode(2, INPUT_PULLUP);
  pinMode(3, INPUT_PULLUP);

  timer1_init_1ms();

  rtcOK = rtcPresent() && rtc.begin();
  sdOK = sd.begin(SD_CS);

  setM(STD, 0, 255, 0);
  restoreModeLed();
  needNormalRefresh = true;
}

// =======================
// LOOP
// =======================
void loop() {
  while (ss.available() > 0) {
    lastGpsByteMs = millis();
    gps.encode(ss.read());
  }

  // BOUTONS
  bool v = (digitalRead(2) == LOW);
  bool r = (digitalRead(3) == LOW);

  if (v) {
    if (bv == 0) bv = millis();
    if (millis() - bv >= 2800 && !bvl) {
      if (mode == STD) setM(ECO, 0, 0, 255);
      bvl = true;
    }
  } else {
    bv = 0;
    bvl = false;
  }

  if (r) {
    if (br == 0) br = millis();
    if (millis() - br >= 2800 && !brl) {
      if (mode != STD) setM(STD, 0, 255, 0);
      else setM(MAINT, 255, 86, 0);
      brl = true;
    }
  } else {
    if (br > 0 && millis() - br < 2800) setM(CONF, 255, 255, 0);
    br = 0;
    brl = false;
  }

  // =======================
  // LECTURES CAPTEURS
  // =======================
  float t = dht.readTemperature();
  float h = dht.readHumidity();

  if (!isnan(t)) lastTemp = t;
  if (!isnan(h)) lastHum = h;

  bool dhtFail = isnan(t) || isnan(h);
  bool sensIncoh = false;

  if (!dhtFail) {
    if (h < 0.0f || h > 100.0f) sensIncoh = true;
    if (t < -40.0f || t > 80.0f) sensIncoh = true;
  }

  int lightValue = lastLight;
  bool lightOK = true;

  if (millis() - lastLightCheck >= LIGHT_CHECK_MS) {
    lightOK = lightSensorPresentHeuristic(lightValue);
    if (lightOK) lastLight = lightValue;
    lastLightCheck = millis();
  } else {
    lightValue = lastLight;
  }

  bool sensorAccessFail = dhtFail || !lightOK;

  // =======================
  // CHECK RTC EN CONTINU
  // =======================
  bool rtcReadable = false;
  if (millis() - lastRtcCheck >= RTC_CHECK_MS) {
    rtcOK = rtcPresent();
    if (rtcOK) rtcOK = rtc.begin();
    lastRtcCheck = millis();
  }

  DateTime dt;
  rtcReadable = rtcOK && rtcTimeReadable(dt);

  // =======================
  // CHECK SD EN CONTINU
  // =======================
  if (millis() - lastSdCheck >= SD_CHECK_MS) {
    sdOK = sdHealthCheck();
    lastSdCheck = millis();
  }

  bool sdRw = !sdOK;
  bool sdFull = false;

  // =======================
  // GPS
  // =======================
  bool gpsFail = (millis() - lastGpsByteMs > GPS_TIMEOUT_MS);

  // =======================
  // CHOIX ERREUR
  // =======================
  bool rtcFail = !rtcReadable;
  ErrorCode newErr = choosePriority(sdRw, sdFull, rtcFail, gpsFail, sensorAccessFail, sensIncoh);

  if (newErr != currentErr) {
    ErrorCode oldErr = currentErr;
    updateError(newErr);

    if (newErr != ERR_NONE) {
      showErrorLCD(newErr);
    } else if (oldErr != ERR_NONE) {
      showFixedLCD();
    }
  }

  // =======================
  // LED PRIORITAIRE ERREUR
  // =======================
  if (currentErr != ERR_NONE) {
    bool doUpdate = false;
    bool second = false;

    cli();
    if (ledUpdateFlag) {
      ledUpdateFlag = false;
      doUpdate = true;
    }
    second = phaseIsSecondColor;
    sei();

    static ErrorCode lastAppliedErr = ERR_NONE;

    if (doUpdate || lastAppliedErr != currentErr) {
      applyErrorLedNow(currentErr, second);
      lastAppliedErr = currentErr;
    }
  } else {
    if (!fixedMsgActive()) {
      restoreModeLed();
    }
  }

  // =======================
  // RETOUR APRES "PROBLEME REGLE"
  // =======================
  if (!fixedMsgActive() && needNormalRefresh && currentErr == ERR_NONE) {
    drawNormalScreen(lastTemp, lastHum, lastLight, true, rtcReadable);
    restoreModeLed();
    dd = millis();
    needNormalRefresh = false;
  }

  // =======================
  // AFFICHAGE NORMAL
  // =======================
  if (currentErr == ERR_NONE && !fixedMsgActive() && (millis() - dd >= 3000)) {
    drawNormalScreen(lastTemp, lastHum, lastLight, lightOK, rtcReadable);
    dd = millis();
  }

  // =======================
  // SAUVEGARDE
  // =======================
  if (millis() - dl >= (mode == ECO ? 1200000UL : 600000UL) && mode != MAINT) {
    if (sdOK) {
      if (sd.exists("L.CSV")) {
        File f = sd.open("L.CSV", FILE_READ);
        if (f) {
          if (f.size() >= MAX_SZ) {
            f.close();
            if (!sd.rename("L.CSV", "O.CSV")) {
              sdFailCount++;
            } else {
              sdFailCount = 0;
            }
          } else {
            f.close();
          }
        } else {
          sdFailCount++;
        }
      }

      logF = sd.open("L.CSV", FILE_WRITE);
      if (logF) {
        if (rtcReadable) logF.print(rtc.now().timestamp());
        else logF.print(F("NO_RTC"));

        logF.print(';');

        if (gps.location.isValid()) logF.print(gps.location.lat(), 6);
        else logF.print(F("NO_GPS"));

        logF.print(';');

        if (!isnan(lastTemp)) logF.print(lastTemp);
        else logF.print(F("NaN"));

        logF.print(';');

        if (!isnan(lastHum)) logF.println(lastHum);
        else logF.println(F("NaN"));

        logF.close();
        sdFailCount = 0;
      } else {
        sdFailCount++;
      }

      if (sdFailCount >= 2) {
        sdOK = false;
      }
    }

    dl = millis();
  }
}
